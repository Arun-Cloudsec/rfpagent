# ─────────────────────────────────────────────────────────────
# RFP Agent — environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" for local dev. On Railway, paste each
# KEY=value pair into the project's Variables tab — DO NOT commit
# real secrets to git.

# ── REQUIRED ─────────────────────────────────────────────────
# Session secret — used to sign auth cookies. Generate with:
#   openssl rand -hex 32
# If you don't set this, every redeploy logs out all users.
SESSION_SECRET=

# Anthropic API key — optional. If set, all users share this key.
# If unset, every user must paste their own key in Settings → Anthropic API Key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Optional but recommended ─────────────────────────────────
# Default Claude model. Override per-request in code if needed.
# Options today: claude-opus-4-7, claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
CLAUDE_MODEL=claude-sonnet-4-6

# Where the JSON-file store lives. On Railway with the default
# ephemeral filesystem this resets on redeploy. To persist, mount
# a Railway Volume at /data and set: DATA_DIR=/data
DATA_DIR=./data

# How many days a login session lasts (default 30)
SESSION_DAYS=30

# Per-IP rate limits (requests per minute)
AI_RATE_PER_MIN=30
GENERAL_RATE_PER_MIN=240

# Hard cap on rows per JSON-file collection (memory safety)
STORAGE_CAP=500

# ── Optional integrations ────────────────────────────────────
# Leave blank to disable (the UI will show "not configured").

# Azure Cost Management (Service Principal credentials)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_SUBSCRIPTION_NAME=

# ElevenLabs Text-to-Speech (executive brief voice-over)
ELEVENLABS_API_KEY=

# ── Runtime ──────────────────────────────────────────────────
# Railway sets PORT automatically; only override locally.
PORT=3000
NODE_ENV=production
